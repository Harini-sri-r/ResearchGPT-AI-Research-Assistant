# Copy this file to .env and replace every placeholder before deployment.

# Application
SECRET_KEY=replace-with-a-long-random-application-secret

# Database
DATABASE_URL=postgresql://researchgpt_user:replace-with-postgres-password@postgres:5432/researchgpt_db
POSTGRES_USER=researchgpt_user
POSTGRES_PASSWORD=replace-with-postgres-password
POSTGRES_DB=researchgpt_db

# JWT
JWT_SECRET_KEY=replace-with-a-different-long-random-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Research services
GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=120
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
CHROMADB_PATH=/app/chromadb
